{
  "name": "@thrillee/aegischat",
  "version": "0.1.0",
  "description": "AegisChat React SDK - Real-time chat and messaging for your applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.mjs",
      "require": "./dist/hooks/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "react",
    "chat",
    "messaging",
    "real-time",
    "websocket",
    "aegischat"
  ],
  "author": "AegisChat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thrillee/aegischat.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
